# =========================
# Core providers
# =========================

# WaveSpeed API key: https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=

# Supabase (Auth + DB): https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (used for webhooks / crediting users securely)
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (payments): https://dashboard.razorpay.com
# - Use NEXT_PUBLIC_RAZORPAY_KEY_ID in the browser (safe)
# - Keep RAZORPAY_KEY_SECRET and RAZORPAY_WEBHOOK_SECRET server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Public app base URL (used in auth redirects if needed)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =========================
# WaveSpeed generation options
# =========================

# Optional: override model (default: google/nano-banana-2/edit-fast)
# WAVESPEED_MODEL=google/nano-banana-2/edit-fast

# Resize each upload before upload + inference (max edge in pixels, JPEG). Default 1280.
# WAVESPEED_INPUT_MAX_EDGE=1280

# Output image resolution for Nano Banana 2 Edit-Fast (2k or 4k). Default 2k.
# WAVESPEED_RESOLUTION=2k

# Output image format (png or jpeg). Default png.
# WAVESPEED_OUTPUT_FORMAT=png

# Aspect ratio: 1:1, 3:2, 2:3, 3:4, 4:3, 4:5, 5:4, 9:16, 16:9, 21:9, 1:4, 4:1, 1:8, 8:1
# WAVESPEED_ASPECT_RATIO=

# Let the model use web search for real-time context. Default false.
# WAVESPEED_WEB_SEARCH=false

# Max time (seconds) to wait for inference to finish. Default 600.
# WAVESPEED_INFERENCE_TIMEOUT_SEC=600

# Opt in to synchronous mode (not recommended for Nano Banana 2).
# WAVESPEED_SYNC_MODE=false

